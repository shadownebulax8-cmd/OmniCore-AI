# ================= App =================
ENV=development

# ================= LLM Provider =================
# Choose ONE: "openai" or "anthropic". Fill in the matching key below.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: enables the agents' web_search tool via https://serper.dev (free tier available)
SERPER_API_KEY=

# ================= Redis (leave as-is for docker-compose) =================
REDIS_HOST=redis
REDIS_PORT=6379

# ================= PostgreSQL (leave as-is for docker-compose) =================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=omni_agent
POSTGRES_PASSWORD=omni_agent_password
POSTGRES_DB=omni_agent_saas

# ================= ChromaDB (leave as-is for docker-compose) =================
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ================= SMTP (support escalation + analysis report emails) =================
# For Gmail: use an "app password", not your real password.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SUPPORT_ESCALATION_EMAIL=

# ================= Rate limiting =================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ================= Semantic cache =================
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92

# ================= Conversation context =================
CONVERSATION_MAX_HISTORY_LENGTH=10
CONVERSATION_SESSION_TTL_SECONDS=3600
